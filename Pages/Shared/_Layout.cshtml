<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - Carlos Palomares" : "BUS 410 Portfolio")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="@(ViewData["BodyClass"] ?? "")">
    <nav>
        <div class="nav-logo">
            <a asp-page="/Index">Carlos <span>Palomares</span></a>
        </div>
        <ul class="nav-links">
            <li>
                <a asp-page="/Index"
                   class="@(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "nav-active" : "")">
                    Home
                </a>
            </li>
            <li>
                <a asp-page="/Resume"
                   class="@(ViewContext.RouteData.Values["page"]?.ToString() == "/Resume" ? "nav-active" : "")">
                    Resume
                </a>
            </li>
            <li class="nav-dropdown">
                <button type="button"
                        class="nav-dropdown-trigger @(ViewContext.RouteData.Values["page"]?.ToString() == "/AIInBusiness" ? "nav-active" : "")">
                    Projects
                </button>
                <ul class="nav-submenu">
                    <li>
                        <a asp-page="/AIInBusiness"
                           class="@(ViewContext.RouteData.Values["page"]?.ToString() == "/AIInBusiness" ? "nav-active" : "")">
                            AI in Business
                        </a>
                    </li>
                </ul>
            </li>
            <li>
                <a asp-page="/PCR"
                   class="@(ViewContext.RouteData.Values["page"]?.ToString() == "/PCR" ? "nav-active" : "")">
                    PCR Activities
                </a>
            </li>
        </ul>
    </nav>
    @RenderBody()
    @if (ViewData["HideFooter"] as bool? != true)
    {
        <footer>
            <div class="footer-inner">
                <p class="footer-brand">&copy; 2026 <span>Carlos Palomares</span></p>
                <div class="footer-contact" aria-label="Contact links">
                    <a href="mailto:palomarescarlitos24@gmail.com">palomarescarlitos24@gmail.com</a>
                    <a href="https://www.linkedin.com/in/carlosalbertopalomares/" target="_blank" rel="noopener">LinkedIn</a>
                    <a href="https://github.com/4sciencee" target="_blank" rel="noopener">GitHub</a>
                    <a href="https://app.joinhandshake.com/profiles/palomares" target="_blank" rel="noopener">Handshake</a>
                </div>
            </div>
        </footer>
    }
    <script>
        (() => {
            const emailAddress = 'palomarescarlitos24@gmail.com';
            let toastTimer;
            let toast = document.querySelector('.copy-cursor-toast');

            if (!toast) {
                toast = document.createElement('div');
                toast.className = 'copy-cursor-toast';
                toast.setAttribute('role', 'status');
                toast.setAttribute('aria-live', 'polite');
                document.body.appendChild(toast);
            }

            const copyEmail = async () => {
                if (navigator.clipboard?.writeText) {
                    await navigator.clipboard.writeText(emailAddress);
                    return;
                }

                const textArea = document.createElement('textarea');
                textArea.value = emailAddress;
                textArea.setAttribute('readonly', '');
                textArea.style.position = 'fixed';
                textArea.style.left = '-9999px';
                document.body.appendChild(textArea);
                textArea.select();
                document.execCommand('copy');
                textArea.remove();
            };

            const showCopiedMessage = (event, target) => {
                const targetRect = target.getBoundingClientRect();
                const x = event.clientX || targetRect.left + targetRect.width / 2;
                const y = event.clientY || targetRect.top;
                const toastWidth = 84;
                const toastHeight = 32;
                const left = Math.min(Math.max(x + 12, 12), window.innerWidth - toastWidth - 12);
                const top = Math.min(Math.max(y - 8, toastHeight + 12), window.innerHeight - 12);

                toast.textContent = 'Copied';
                toast.style.left = `${left}px`;
                toast.style.top = `${top}px`;
                toast.classList.add('is-visible');

                window.clearTimeout(toastTimer);
                toastTimer = window.setTimeout(() => {
                    toast.classList.remove('is-visible');
                }, 1400);
            };

            document.addEventListener('click', async (event) => {
                const link = event.target.closest(`a[href="mailto:${emailAddress}"]`);

                if (!link) {
                    return;
                }

                event.preventDefault();

                try {
                    await copyEmail();
                    showCopiedMessage(event, link);
                } catch {
                    showCopiedMessage(event, link);
                }
            });
        })();

        (() => {
            const prefetched = new Set();
            const canPrefetch = (url) => {
                return url.origin === window.location.origin
                    && (url.pathname.startsWith('/ai-business-labs/') || url.pathname === '/AIInBusiness');
            };
            const prefetch = (href) => {
                try {
                    const url = new URL(href, window.location.href);

                    if (!canPrefetch(url) || prefetched.has(url.href)) {
                        return;
                    }

                    prefetched.add(url.href);
                    const link = document.createElement('link');
                    link.rel = 'prefetch';
                    link.as = 'document';
                    link.href = url.href;
                    document.head.appendChild(link);
                } catch {
                    return;
                }
            };
            const scheduleIdle = (callback) => {
                if ('requestIdleCallback' in window) {
                    window.requestIdleCallback(callback, { timeout: 1800 });
                    return;
                }

                window.setTimeout(callback, 900);
            };

            document.querySelectorAll('a[href]').forEach((link) => {
                const warm = () => prefetch(link.href);
                link.addEventListener('pointerenter', warm, { once: true });
                link.addEventListener('focus', warm, { once: true });
                link.addEventListener('touchstart', warm, { once: true, passive: true });
            });

            scheduleIdle(() => {
                document.querySelectorAll('a[href^="/ai-business-labs/"]').forEach((link, index) => {
                    window.setTimeout(() => prefetch(link.href), index * 140);
                });
            });
        })();
    </script>
</body>
</html>
