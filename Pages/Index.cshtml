@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
    ViewData["BodyClass"] = "home-page";
}

<!-- ── HERO SECTION ── -->
<div class="hero">
    <div class="hero-inner">
        <div class="hero-grid">

            <!-- LEFT: Text -->
            <div class="hero-text">
                <p class="hero-eyebrow">Welcome to my portfolio</p>
                <h1>Hi, I'm <em>Carlos Palomares</em></h1>
                <p class="hero-role">Management Information Systems Student</p>
                <p class="hero-tagline">
                    Business Administration student at Western Washington University,
                    passionate about how technology and data can solve real problems
                    and drive smarter decisions.
                </p>
                <div class="hero-badges">
                    <span class="badge accent">Business Administration (MIS)</span>
                    <span class="badge">Spring 2026</span>
                    <span class="badge">Bellingham, WA</span>
                </div>
            </div>

            <!-- RIGHT: Photo -->
            <div class="hero-photo">
                <div class="hero-photo-wrap">
                    <div class="hero-photo-deco"></div>
                    <div class="hero-photo-frame">
                        <img src="~/files/profile-pic.jpg" alt="Carlos Palomares" />
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

